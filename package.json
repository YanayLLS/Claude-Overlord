{
  "name": "overlord",
  "version": "1.0.0",
  "description": "Overlord — Claude Agent Manager",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/bundle-xterm.js && electron .",
    "dev": "node scripts/bundle-xterm.js && electronmon .",
    "package": "node scripts/bundle-xterm.js && electron-builder --dir",
    "dist": "node scripts/bundle-xterm.js && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-web-links": "^0.12.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.overlord.claude",
    "productName": "Overlord",
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "xterm-bundle.js",
      "xterm.css"
    ],
    "directories": {
      "output": "out"
    },
    "asar": true,
    "npmRebuild": false
  }
}
